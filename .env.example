# ============================================================================
# AAPel — environment variables (development defaults)
# ============================================================================
# Copy this to `.env` for local dev. Both Docker Compose AND the FastAPI
# config (via Pydantic Settings) read from this file.
#
# NEVER commit `.env` — it is excluded by `.gitignore`.
#
# In production (Magalu VPS), these values come from /etc/aapel/secrets/*.env
# (chmod 640, owner root:docker), sourced by scripts/deploy.sh — not from
# this file. See ARCHITECTURE.md §12.
# ============================================================================

# -- Domain ------------------------------------------------------------------
# Dev: localhost. Prod: <ip-with-dashes>.nip.io provisionally,
# e.g. 191-235-100-50.nip.io for a VPS at 191.235.100.50.
AAPEL_DOMAIN=localhost
ACME_EMAIL=admin@aapel.local

# -- Database ----------------------------------------------------------------
POSTGRES_USER=aapel
POSTGRES_PASSWORD=aapel_dev_password_change_me
POSTGRES_DB=aapel

# Built from above by compose; exported into containers (host:db inside compose
# network, host:localhost when running drizzle-kit / scripts from the host).
DATABASE_URL=postgresql://aapel:aapel_dev_password_change_me@localhost:5432/aapel

# -- JWT ---------------------------------------------------------------------
# Generate strong secrets in prod:  openssl rand -base64 48
JWT_SECRET=dev_secret_REPLACE_with_openssl_rand_base64_48
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# -- LGPD --------------------------------------------------------------------
# Pepper for analytics customer hash. NEVER reuse JWT_SECRET.
ANALYTICS_PEPPER=dev_pepper_REPLACE_in_prod

# -- bcrypt ------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -- CORS / origins ----------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# -- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
INTERNAL_API_URL=http://api:8000

# -- NextAuth.js (for Phase 3 BFF integration) -------------------------------
# openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# -- Admin bootstrap (used by `pnpm db:seed`) --------------------------------
ADMIN_EMAIL=admin@aapel.local
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin AAPel

# -- App misc ----------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
